# API and deterministic runtime budgets. Copy this file to .env for Docker use;
# never commit the resulting .env because it may contain local authentication.
DATAOPS_ENVIRONMENT=development
DATAOPS_LOG_LEVEL=INFO
DATAOPS_HOST=0.0.0.0
DATAOPS_PORT=8000
DATAOPS_API_PORT=18000
DATAOPS_MAX_REACT_STEPS=6
# This wall-clock budget covers Planner decisions, LangGraph scheduling, and MCP calls.
# It is separate from the per-tool timeout and prevents a sequence of legal calls hanging a run.
DATAOPS_REACT_TOTAL_TIMEOUT_SECONDS=60
DATAOPS_MAX_GRAPH_HOPS=2
DATAOPS_MAX_AUDIT_REVISIONS=1
DATAOPS_TOOL_TIMEOUT_SECONDS=5
DATAOPS_TOOL_RETRY_COUNT=1
# The offline deterministic provider keeps tests and the portfolio demo runnable
# without credentials. Replace the provider through the shared interface rather
# than coupling PostgreSQL queries to a model SDK; changing algorithms requires
# a new versioned provider ID so old and new vector spaces never mix.
DATAOPS_EMBEDDING_PROVIDER=deterministic-hash:v1
DATAOPS_EMBEDDING_DIMENSIONS=128
# Hybrid score weights map directly to semantic, lexical, graph-path, source
# reliability, and case-freshness components and must sum to exactly 1.0.
DATAOPS_RETRIEVAL_SEMANTIC_WEIGHT=0.45
DATAOPS_RETRIEVAL_LEXICAL_WEIGHT=0.10
DATAOPS_RETRIEVAL_PATH_WEIGHT=0.25
DATAOPS_RETRIEVAL_RELIABILITY_WEIGHT=0.10
DATAOPS_RETRIEVAL_FRESHNESS_WEIGHT=0.10
# Evidence bundle budgets count exact UTF-8 bytes for selected node/path JSON.
# Node and path caps remain separate so many short records cannot bypass context control.
DATAOPS_RETRIEVAL_CONTEXT_MAX_BYTES=6000
DATAOPS_RETRIEVAL_CONTEXT_MAX_NODES=8
DATAOPS_RETRIEVAL_CONTEXT_MAX_PATHS=4
DATAOPS_FIXTURE_DIRECTORY=data/fixtures/scenarios
DATAOPS_GOLDEN_CASE_FILE=data/fixtures/golden_cases.json
# Graph seed and local PostgreSQL settings. DATAOPS_DB_AUTH is a placeholder for
# a local-only credential and is interpolated by Docker Compose, not logged by API.
DATAOPS_KNOWLEDGE_SEED_FILE=data/knowledge/cross_chain_graph.json
DATAOPS_DB_AUTH=replace_for_local_development
DATAOPS_DB_PORT=15432
