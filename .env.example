# API and deterministic runtime budgets. Copy this file to .env for Docker use;
# never commit the resulting .env because it may contain local authentication.
DATAOPS_ENVIRONMENT=development
DATAOPS_LOG_LEVEL=INFO
DATAOPS_HOST=0.0.0.0
DATAOPS_PORT=8000
DATAOPS_API_PORT=18000
DATAOPS_MAX_REACT_STEPS=6
DATAOPS_MAX_GRAPH_HOPS=2
DATAOPS_MAX_AUDIT_REVISIONS=1
DATAOPS_TOOL_TIMEOUT_SECONDS=5
DATAOPS_TOOL_RETRY_COUNT=1
DATAOPS_FIXTURE_DIRECTORY=data/fixtures/scenarios
DATAOPS_GOLDEN_CASE_FILE=data/fixtures/golden_cases.json
# Graph seed and local PostgreSQL settings. DATAOPS_DB_AUTH is a placeholder for
# a local-only credential and is interpolated by Docker Compose, not logged by API.
DATAOPS_KNOWLEDGE_SEED_FILE=data/knowledge/cross_chain_graph.json
DATAOPS_DB_AUTH=replace_for_local_development
DATAOPS_DB_PORT=15432
