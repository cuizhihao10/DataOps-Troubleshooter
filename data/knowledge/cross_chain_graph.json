      "name": "BDS 数据倾斜",
      "content": "热点键或分桶记录量显著高于中位数时，少量执行器溢写并形成阶段长尾。",
      "aliases": ["data skew", "hot partition", "DATA_SKEW_DETECTED"],
      "source_id": "synthetic_cross_chain_knowledge_v3",
      "source_span": "高倾斜比与热点分桶溢写共同支持数据倾斜根因。",
      "reliability": 1.0,
      "embedding": null
    },
    {
      "node_id": "solution_rebalance_bds_skew",
